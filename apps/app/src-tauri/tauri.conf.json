{
  "$schema": "../../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "myDon",
  "version": "0.2.0",
  "identifier": "app.mydon.app",
  "build": {
    "frontendDist": "../../../dist/apps/app/browser",
    "devUrl": "http://localhost:4200",
    "beforeDevCommand": "pnpm start:app",
    "beforeBuildCommand": "pnpm nx build app"
  },
  "app": {
    "windows": [
      {
        "title": "myDon",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
