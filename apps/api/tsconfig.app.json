{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "nodenext",
    "types": ["node", "express", "multer"],
    "emitDecoratorMetadata": true,
    "target": "ES2024",
    "moduleResolution": "nodenext"
  },
  "exclude": ["jest.config.ts", "src/**/*.spec.ts", "src/**/*.test.ts", "src/data-source.ts", "src/migrations"],
  "include": ["src/**/*.ts"]
}
