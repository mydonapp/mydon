{
  "name": "mydon",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:24",

  "runArgs": ["--add-host=host.docker.internal:host-gateway"],

  "appPort": [3000, 4200],

  "mounts": [
    {
      "source": "mydon-node_modules",
      "target": "${containerWorkspaceFolder}/node_modules",
      "type": "volume"
    },
    {
      "source": "mydon-pnpm-store",
      "target": "/pnpm-store",
      "type": "volume"
    }
  ],

  "postCreateCommand": "sudo chown -R node:node ${containerWorkspaceFolder}/node_modules && corepack enable && ([ -f .env ] || (cp .env.example .env && sed -i 's/^DB_POSTGRES_HOST=.*/DB_POSTGRES_HOST=host.docker.internal/' .env)) && pnpm install",

  "customizations": {
    "vscode": {
      "extensions": ["angular.ng-template", "dbaeumer.vscode-eslint", "esbenp.prettier-vscode", "nrwl.angular-console"],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode"
      }
    }
  }
}
